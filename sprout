#!/bin/sh
# sprout — universal project scaffolder. Interactive wizard by default; flags for CI.
# Two planes: global CLIs (validated, not vendored) + Agent Skills (downloaded & vendored).
set -e

# ── resolve real dir (follow symlinks) ───────────────────────────────────────
SELF="$0"
while [ -L "$SELF" ]; do
    L="$(readlink "$SELF")"
    case "$L" in
        /*) SELF="$L" ;;
        *)  SELF="$(dirname "$SELF")/$L" ;;
    esac
done
SPROUT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
export SPROUT_DIR

. "$SPROUT_DIR/lib/common.sh"
. "$SPROUT_DIR/lib/prompt.sh"

VERSION="0.1.0"
TYPES="web fullstack desktop mobile ext cli"
TAB="$(printf '\t')"

# defaults
DRY_RUN=0
AGENTS_SEL="claude"
SKILLS_SEL=""
INSTALL_CLIS=0
CLIS_INSTALL=""
STACK=""
DB=""          # fullstack database: sqlite|postgres|mysql
PM=""
# web stack choices (recipe-specific; set by the wizard or these flags)
BASE=""        # astro | vanilla
CSS=""         # none | sass | less | tailwind | bootstrap
LANG=""        # ts | js
LINTER=""      # biome | eslint | none
TESTING=""     # none | playwright | vitest
GIT_INIT=0     # 1 = git init + first commit
SDD_INIT=0     # 1 = install the SDD plane (kit + flow skills) into the project
NONINTERACTIVE=0

usage() {
    cat <<EOF
sprout $VERSION — scaffold a project with your stack, skills and agent context ready.

Usage:
  sprout                                  interactive wizard (default)
  sprout <type> <name> [options]          non-interactive
  sprout list | doctor | skills <cmd> | sdd <cmd>

Types:   web  fullstack  desktop  mobile  ext  cli  (Phase 1 ships: web)

Options:
  --pm <name>             JS package manager for web · desktop/tauri · mobile/react-native ·
                          ext/wxt: pnpm|npm|yarn|bun (def: pnpm if present)
  --base <name>           web base: astro|vanilla (def: astro)
  --css <name>            web css: none|sass|less|tailwind|bootstrap (def: tailwind)
  --lang <name>           language for web · desktop/tauri · mobile/react-native: ts|js (def: ts)
  --linter <name>         web linter: none|biome|eslint (def: none)
  --test "a,b"            web testing (any/both): playwright,vitest (def: none)
  --git / --no-git        git init + first commit after scaffold (def: no)
  --sdd / --no-sdd        install the SDD plane (kit + flow skills) (def: no)
  --stack <name>          stack variant (e.g. fullstack: laravel|django|fastapi; cli: sh|rust|go)
  --skills "a,b@1.2.0"    override the skill set; pin a skill with name@ref
  --agent  "claude gemini codex copilot opencode"   agent context to wire (def: claude)
  --clis   "gh,fzf"       install only these missing global CLIs (the wizard sets this)
  --install-clis          install ALL missing global CLIs (default: only warn)
  --dry-run               print what would happen, do nothing
  -h, --help              this help
      --version           print version

Skills subcommands (run inside a generated project, or pass a dir):
  sprout skills add <name[@ref]> [dir]    download & vendor one more skill
  sprout skills update [name] [dir]       re-resolve to latest, update lock + table

SDD subcommands (spec-driven development plane — new or existing project):
  sprout sdd init [dir]                       install the SDD kit + flow skills (def: .)
  sprout sdd spec new <feature> [dir]         scaffold a per-feature brief (sdd/specs/<feature>/brief.md)
  sprout sdd waves <feature> [dir]            show execution waves (multi-agent: parallel vs wait)
  sprout sdd handoff <feature> <phase> [dir]  write a self-contained brief for one phase

Examples:
  sprout
  sprout web my-site
  sprout web my-site --skills "frontend-design@1.2.0,impeccable" --agent "claude gemini"
  sprout --dry-run web demo
EOF
}

# ── shared helpers used by recipes ───────────────────────────────────────────

# skills_for_type <type> -> space-separated skill names (core + type set)
skills_for_type() {
    _c="$(read_list "$SPROUT_DIR/sets/core.list")"
    _t="$(read_list "$SPROUT_DIR/sets/$1.list")"
    printf '%s %s' "$_c" "$_t" | tr -s ' '
}

# skill_items_for_type <type> — "name|name — <what it's for>" lines for the wizard,
# pulling the short description from the registry's auto_invoke column.
skill_items_for_type() {
    for _s in $(skills_for_type "$1"); do
        _d="$(awk -F '\t' -v n="$_s" '
            /^[[:space:]]*#/ { next } { gsub(/^[ \t]+|[ \t]+$/, "", $1) }
            $1 == n { print $5; exit }' "$SPROUT_DIR/skills/registry.tsv")"
        if [ -n "$_d" ]; then printf '%s|%-27s — %s\n' "$_s" "$_s" "$_d"
        else                  printf '%s|%s\n' "$_s" "$_s"; fi
    done
}

# clis_for_type <type> — "name|name (installed|missing) — <desc>" lines for the picker
clis_for_type() {
    _t="$1"
    while IFS="$TAB" read -r name brew pac apt dnf zyp phase types desc; do
        case "$name" in ''|\#*|name) continue ;; esac
        echo "$types" | tr ',' '\n' | grep -qx core 2>/dev/null \
            || echo "$types" | tr ',' '\n' | grep -qx "$_t" 2>/dev/null || continue
        _tag="(missing)"; have "$name" && _tag="(installed)"
        [ "$_tag" = "(missing)" ] && echo "$types" | tr ',' '\n' | grep -qx optional 2>/dev/null && _tag="(optional)"
        printf '%s|%-13s %-11s — %s\n' "$name" "$name" "$_tag" "$desc"
    done < "$SPROUT_DIR/clis/manifest.tsv"
}

# clis_missing <type> — space-separated names of core+type CLIs not on PATH.
# Optional CLIs are never preselected (you opt in via the picker).
clis_missing() {
    _t="$1"; _out=""
    while IFS="$TAB" read -r name brew pac apt dnf zyp phase types desc; do
        case "$name" in ''|\#*|name) continue ;; esac
        echo "$types" | tr ',' '\n' | grep -qx core 2>/dev/null \
            || echo "$types" | tr ',' '\n' | grep -qx "$_t" 2>/dev/null || continue
        echo "$types" | tr ',' '\n' | grep -qx optional 2>/dev/null && continue
        have "$name" || _out="$_out $name"
    done < "$SPROUT_DIR/clis/manifest.tsv"
    printf '%s' "$_out" | sed 's/^ *//'
}

# apply_overlay <project_dir> <type> — copy common + type overlay over the scaffold.
# Preserves the scaffolder's .gitignore (merges overlay lines in) instead of clobbering it.
apply_overlay() {
    _dir="$1"; _type="$2"
    say "applying overlay (common + $_type)"
    if [ "${DRY_RUN:-0}" = 1 ]; then
        for _src in "$SPROUT_DIR/overlays/common" "$SPROUT_DIR/overlays/$_type"; do
            [ -d "$_src" ] && dim "  would copy $_src/* into $_dir (merging .gitignore)"
        done
        return 0
    fi
    for _src in "$SPROUT_DIR/overlays/common" "$SPROUT_DIR/overlays/$_type"; do
        [ -d "$_src" ] || continue
        # remember the scaffolder's .gitignore so cp doesn't lose it
        _keep=""; [ -f "$_dir/.gitignore" ] && _keep="$(cat "$_dir/.gitignore")"
        cp -R "$_src/." "$_dir/" 2>/dev/null || true
        if [ -n "$_keep" ] && [ -f "$_src/.gitignore" ]; then
            printf '%s\n' "$_keep" > "$_dir/.gitignore"          # scaffolder lines first
            while IFS= read -r _l || [ -n "$_l" ]; do            # then overlay's unique lines
                [ -n "$_l" ] || continue
                grep -qxF "$_l" "$_dir/.gitignore" 2>/dev/null || printf '%s\n' "$_l" >> "$_dir/.gitignore"
            done < "$_src/.gitignore"
        fi
    done
}

# render_agents_md <project_dir> <name> <type> <stack>
render_agents_md() {
    _dir="$1"; _name="$2"; _type="$3"; _stack="${4:-—}"
    say "writing AGENTS.md"
    if [ "$DRY_RUN" = 1 ]; then dim "  would render $_dir/AGENTS.md from template"; return 0; fi
    sed -e "s/{{PROJECT_NAME}}/$_name/g" \
        -e "s/{{PROJECT_TYPE}}/$_type/g" \
        -e "s/{{PROJECT_STACK}}/$_stack/g" \
        "$SPROUT_DIR/templates/AGENTS.md.tmpl" > "$_dir/AGENTS.md"
}

# render_sdd_kit <project_dir> — install the SDD process plane (3rd plane): drop the
# editable kit into <project>/sdd/ and the sdd-* flow skills into <project>/skills/ (so
# sync-agents.sh lists them in the auto-invoke table). Idempotent: preserves a user-edited
# config.yaml / spec.prompt.md, refreshes templates + the flow skills.
render_sdd_kit() {
    _dir="$1"
    say "installing SDD kit (sdd/ + sdd-* flow skills)"
    if [ "${DRY_RUN:-0}" = 1 ]; then
        dim "  would copy sdd/kit/* into $_dir/sdd and the sdd-* skills into $_dir/skills"
        return 0
    fi
    mkdir -p "$_dir/sdd" "$_dir/skills"
    # flow skills -> project skills/ (auto-invoke table picks them up)
    cp -R "$SPROUT_DIR/sdd/skills/." "$_dir/skills/"
    # kit -> project sdd/. Refresh templates + README; never clobber user-edited files.
    cp -R "$SPROUT_DIR/sdd/kit/templates" "$_dir/sdd/" 2>/dev/null || true
    cp "$SPROUT_DIR/sdd/kit/README.md" "$_dir/sdd/README.md" 2>/dev/null || true
    [ -f "$_dir/sdd/config.yaml" ]    || cp "$SPROUT_DIR/sdd/kit/config.yaml"    "$_dir/sdd/config.yaml"
    [ -f "$_dir/sdd/spec.prompt.md" ] || cp "$SPROUT_DIR/sdd/kit/spec.prompt.md" "$_dir/sdd/spec.prompt.md"
    ok "SDD kit ready in $_dir/sdd"
}

# validate_clis <type> — check presence of core+type CLIs; warn or install missing
validate_clis() {
    _type="$1"; _missing=0
    head "CLIs (global)"
    while IFS="$TAB" read -r name brew pac apt dnf zyp phase types desc; do
        case "$name" in ''|\#*|name) continue ;; esac
        # applies if types contains "core" or the project type
        echo "$types" | tr ',' '\n' | grep -qx core 2>/dev/null \
            || echo "$types" | tr ',' '\n' | grep -qx "$_type" 2>/dev/null || continue
        if have "$name"; then
            ok "present: $name"
            continue
        fi
        # already installed under a distro-renamed binary (fd-find→fdfind)? link, don't reinstall.
        if link_alias "$name"; then continue; fi
        _opt=0; echo "$types" | tr ',' '\n' | grep -qx optional 2>/dev/null && _opt=1
        if [ "$INSTALL_CLIS" = 1 ] || in_list "$name" "${CLIS_INSTALL:-}"; then
            say "installing $name"
            pkg_install "$brew" "$pac" "$apt" "$dnf" "$zyp"
            link_alias "$name"   # make it usable under the expected command name
        elif [ "$_opt" = 1 ]; then
            dim "  optional: $name not installed — $desc"
        else
            _missing=1
            warn "missing: $name  (pkg: brew '$brew' / pacman '$pac' / apt '$apt' / dnf '$dnf' / zypper '$zyp', or rerun with --install-clis)"
        fi
    done < "$SPROUT_DIR/clis/manifest.tsv"
    [ "$_missing" = 0 ] && ok "all required CLIs present"
    return 0
}

# ── doctor helpers ─────────────────────────────────────────────────────────────
# _chk_any "<ok-label>" "<miss-hint>" cmd1 cmd2 ...  — ok if ANY cmd is present.
_chk_any() {
    _lbl="$1"; _hint="$2"; shift 2
    for _c in "$@"; do have "$_c" && { ok "$_lbl ($_c)"; return 0; }; done
    warn "$_hint"
}

# ── subcommands ──────────────────────────────────────────────────────────────

cmd_list() {
    head "Types";  printf '  %s\n' $TYPES
    head "Skills (registry)"
    awk -F "$TAB" '/^[[:space:]]*#/||$1=="name"{next} NF>=5 {printf "  %-28s %s\n", $1, $5}' "$SPROUT_DIR/skills/registry.tsv"
    head "CLIs (manifest)"
    awk -F "$TAB" '/^[[:space:]]*#/||$1=="name"{next} NF>=9 {printf "  %-14s %s\n", $1, $9}' "$SPROUT_DIR/clis/manifest.tsv"
}

cmd_doctor() {
    head "base"
    if have git; then ok "present: git"
    else warn "missing: git — needed for 'git init' and skill downloads"; fi
    _js="$(default_pm_js)"
    if have "$_js"; then ok "JS package manager: $_js"
    else warn "no JS package manager (pnpm/npm/yarn/bun) — needed for web, ext, mobile (expo)"; fi

    head "scaffolders & toolchains (per type — only what you'll scaffold)"
    dim "  web       — uses your JS package manager (Astro/Vite); no extra tool"
    _chk_any "fullstack/laravel" \
        "fullstack(laravel): install PHP + 'composer' or the 'laravel' installer (laravel.com); or use --stack django|fastapi" \
        laravel composer
    _chk_any "fullstack/python" \
        "fullstack(django|fastapi): install 'uv' (astral.sh/uv) or python3" \
        uv python3
    _chk_any "desktop/tauri+egui (Rust)" \
        "desktop(tauri|egui): install Rust via rustup.rs ('cargo')" \
        cargo
    _chk_any "desktop/wails+fyne (Go)" \
        "desktop(wails|fyne): install Go (go.dev); wails also needs the 'wails' CLI (wails.io)" \
        go
    _chk_any "mobile/flutter" \
        "mobile(flutter): install the Flutter SDK (flutter.dev)" \
        flutter
    _chk_any "mobile/swift" \
        "mobile(swift): install Xcode / the Swift toolchain" \
        swift
    dim "  mobile/react-native & ext — use your JS package manager (Expo/wxt via npx)"

    validate_clis core
}

cmd_skills() {
    _sub="${1:-}"; shift 2>/dev/null || true
    case "$_sub" in
        add)
            _spec="$1"; _dir="${2:-$PWD}"
            [ -n "$_spec" ] || { err "usage: sprout skills add <name[@ref]> [dir]"; exit 1; }
            DRY_RUN="$DRY_RUN" "$SPROUT_DIR/skills/resolve.sh" "$_dir" "$_spec"
            "$SPROUT_DIR/skills/sync-agents.sh" "$_dir" ;;
        update)
            _name="$1"; _dir="${2:-$PWD}"
            if [ -n "$_name" ] && [ -d "$_name" ]; then _dir="$_name"; _name=""; fi
            if [ -n "$_name" ]; then _specs="$_name@latest"; else
                _specs="$(awk -F "$TAB" '/^[[:space:]]*#/{next} NF>=1{print $1"@latest"}' "$_dir/skills.lock" 2>/dev/null | tr '\n' ' ')"
            fi
            [ -n "$_specs" ] || { err "nothing to update in $_dir"; exit 1; }
            # shellcheck disable=SC2086
            DRY_RUN="$DRY_RUN" "$SPROUT_DIR/skills/resolve.sh" "$_dir" $_specs
            "$SPROUT_DIR/skills/sync-agents.sh" "$_dir" ;;
        *) err "unknown skills subcommand: '$_sub' (use add|update)"; exit 1 ;;
    esac
}

# ── sdd orchestration (Phase 5): waves + per-phase handoff briefs ────────────────────────
# sdd_waves <feature_dir> — read each phase's Agent/Depends-on from plan.md and print the
# execution waves: phases with all deps satisfied run together (parallel); the rest wait.
sdd_waves() {
    _plan="$1/plan.md"
    [ -f "$_plan" ] || { err "sdd waves: no plan.md at '$_plan' — run sdd-plan first"; return 1; }
    head "sprout sdd waves — $(basename "$1")"
    dim "  legend: ║ = run in parallel · waves run top-to-bottom"
    awk '
        function trim(s){ sub(/^[ \t]+/,"",s); sub(/[ \t]+$/,"",s); return s }
        /^## Phase [0-9]+/ { n=$3+0; np++; order[np]=n; agent[n]="?"; deps[n]=""; next }
        /^- \*\*Agent:\*\*/ && n     { a=$0; sub(/^- \*\*Agent:\*\*[ ]*/,"",a); sub(/<!--.*$/,"",a); a=trim(a); if(a!="") agent[n]=a; next }
        /^- \*\*Depends on:\*\*/ && n { d=$0; sub(/^- \*\*Depends on:\*\*[ ]*/,"",d); sub(/<!--.*$/,"",d); gsub(/[^0-9]+/," ",d); deps[n]=trim(d); next }
        END {
            if(np==0){ print "  (no phases found in plan.md)"; exit 0 }
            for(i=1;i<=np;i++){ pending[order[i]]=1; left++ }
            wave=0
            while(left>0){
                cnt=0
                for(i=1;i<=np;i++){ p=order[i]; if(!pending[p]) continue
                    ready=1; m=split(deps[p],dd," ")
                    for(j=1;j<=m;j++) if(!done[dd[j]+0]) ready=0
                    if(ready){ cnt++; cur[cnt]=p }
                }
                if(cnt==0){ print "  !! dependency cycle or unknown phase ref — check the Depends on: lines"; exit 1 }
                wave++; kind=(cnt>1)?"paralelo":"serial"; line=""
                for(k=1;k<=cnt;k++){ p=cur[k]; seg="Phase " p " [" agent[p] "]"; line=(k==1)?seg:line" ║ "seg }
                printf "  Onda %d (%-8s) %s\n", wave, kind, line
                for(k=1;k<=cnt;k++){ done[cur[k]]=1; pending[cur[k]]=0; left-- }
            }
        }
    ' "$_plan"
}

# sdd_handoff <feature_dir> <phase> <project_dir> — assemble a self-contained brief for one
# phase (the phase block + the spec's goal/ACs/Contract + project conventions + scope rules)
# at <feature_dir>/handoffs/phase-<n>.md, ready to paste into that phase's agent.
sdd_handoff() {
    _p="$1"; _phase="$2"; _proj="$3"
    _plan="$_p/plan.md"; _spec="$_p/spec.md"; _cfg="$_proj/sdd/config.yaml"
    [ -f "$_plan" ] || { err "sdd handoff: no plan.md at '$_plan' — run sdd-plan first"; return 1; }
    [ -f "$_spec" ] || { err "sdd handoff: no spec.md at '$_spec'"; return 1; }
    case "$_phase" in ''|*[!0-9]*) err "sdd handoff: <phase> must be a number (e.g. 2)"; return 1 ;; esac
    _block="$(extract_md_section "$_plan" "^## Phase ${_phase}([^0-9]|\$)")"
    [ -n "$_block" ] || { err "sdd handoff: Phase $_phase not found in plan.md"; return 1; }
    # NB: `head` is a logging function in common.sh — never pipe to it; one match per block anyway.
    _agent="$(printf '%s\n' "$_block" | sed -n 's/^- \*\*Agent:\*\* *//p' | sed 's/[[:space:]]*<!--.*$//')"; : "${_agent:=claude}"
    _covers="$(printf '%s\n' "$_block" | sed -n 's/^- \*\*Covers:\*\* *//p' | sed 's/[[:space:]]*<!--.*$//')"
    _goal="$(extract_md_section "$_spec" '^## Goal' | tail -n +2)"
    _ac="$(extract_md_section "$_spec" '^## Acceptance criteria' | tail -n +2)"
    _contract="$(extract_md_section "$_spec" '^## Contract' | tail -n +2)"
    [ -n "$(printf '%s' "$_contract" | tr -d '[:space:]')" ] || _contract="(no Contract section in spec.md — N/A for a single-surface feature)"
    # conventions: just the context.* and commands.* scalars (inline comments stripped)
    _conv="$(awk '
        /^context:/  { print "context:";  sec=1; next }
        /^commands:/ { print "commands:"; sec=1; next }
        /^[^[:space:]#]/ { sec=0 }
        sec && /^[[:space:]]+[a-z_]+:/ { line=$0; sub(/[ \t]*#.*$/,"",line); print line }
    ' "$_cfg" 2>/dev/null)"
    _dest_dir="$_p/handoffs"; _dest="$_dest_dir/phase-${_phase}.md"
    head "sprout sdd handoff — $(basename "$_p") · Phase $_phase → $_agent"
    if [ "${DRY_RUN:-0}" = 1 ]; then dim "  would write the brief to $_dest"; return 0; fi
    mkdir -p "$_dest_dir"
    cat > "$_dest" <<EOF
# Handoff — $(basename "$_p") · Phase $_phase  →  agent: $_agent

> Self-contained brief generated by \`sprout sdd handoff\`. Paste this whole file into the
> **$_agent** agent. Implement ONLY this phase; do not start other phases. Build strictly
> against the Contract below — do not invent data shapes or endpoints.

## Your phase (from plan.md)

$_block

## Goal (from the spec)
$_goal

## Acceptance criteria — this phase covers: ${_covers:-(see plan)}
$_ac

## Contract — freeze; build against this exactly
$_contract

## Project conventions (sdd/config.yaml)

\`\`\`yaml
$_conv
\`\`\`

## Rules

- Implement only Phase $_phase's tasks. Keep the diff small; tick \`- [x]\` as you finish each.
- Follow the conventions above and the repo's existing style.
- Build against the Contract exactly. If something is missing or ambiguous, STOP and ask —
  a wrong guess here breaks integration with the other agents' phases.
- When done, hand back for review against the acceptance criteria (Claude / \`sdd-verify\`).
EOF
    ok "handoff ready: $_dest"
    dim "  open the $_agent agent and paste $_dest"
}

# ── sdd: install the spec-driven-development plane into a project (new or existing) ──────
cmd_sdd() {
    _sub="${1:-}"; shift 2>/dev/null || true
    case "$_sub" in
        init)
            _dir="${1:-$PWD}"
            [ -d "$_dir" ] || { err "sdd init: '$_dir' is not a directory"; exit 1; }
            head "sprout sdd — installing the SDD plane in $_dir"
            # need an AGENTS.md to host the auto-invoke table; create a minimal one if absent
            if [ ! -f "$_dir/AGENTS.md" ]; then
                if [ "${DRY_RUN:-0}" = 1 ]; then dim "  would create a minimal AGENTS.md"
                else
                    render_agents_md "$_dir" "$(basename "$_dir")" existing "—"
                fi
            fi
            render_sdd_kit "$_dir"
            DRY_RUN="$DRY_RUN" "$SPROUT_DIR/skills/sync-agents.sh" "$_dir"
            head "done"
            ok  "SDD plane ready in $_dir"
            dim "  1. edit  sdd/config.yaml   (test/lint/build commands + context)"
            dim "  2. new feature: sprout sdd spec new <feature>  then fill its brief.md"
            dim "  3. flow: draft the spec → plan it → build phase 1 → verify" ;;
        spec)
            _spec_cmd="${1:-}"; shift 2>/dev/null || true
            case "$_spec_cmd" in
                new)
                    _feat="${1:-}"; _dir="${2:-$PWD}"
                    [ -n "$_feat" ] || { err "sdd spec new: missing <feature> name"; exit 1; }
                    case "$_feat" in
                        -*|*-|*[!a-z0-9-]*) err "sdd spec new: '$_feat' must be kebab-case (a-z, 0-9, -)"; exit 1 ;;
                    esac
                    [ -d "$_dir/sdd" ] || { err "sdd spec new: no sdd/ in '$_dir' — run 'sprout sdd init' first"; exit 1; }
                    _src="$_dir/sdd/spec.prompt.md"; [ -f "$_src" ] || _src="$SPROUT_DIR/sdd/kit/spec.prompt.md"
                    _dest_dir="$_dir/sdd/specs/$_feat"; _dest="$_dest_dir/brief.md"
                    [ -f "$_dest" ] && { err "sdd spec new: '$_dest' already exists — not overwriting"; exit 1; }
                    head "sprout sdd spec — new brief for '$_feat'"
                    if [ "${DRY_RUN:-0}" = 1 ]; then
                        dim "  would create $_dest_dir/ and copy the brief template → $_dest"
                    else
                        mkdir -p "$_dest_dir"
                        cp "$_src" "$_dest"
                        ok "brief ready: $_dest"
                        dim "  1. fill  sdd/specs/$_feat/brief.md  (goal, users, acceptance criteria)"
                        dim "  2. ask your agent to \"draft the spec for $_feat\"  → writes spec.md alongside it"
                    fi ;;
                ""|-h|--help)
                    cat <<EOF
sprout sdd spec — scaffold a per-feature spec brief

Usage:
  sprout sdd spec new <feature> [dir]   create sdd/specs/<feature>/brief.md from the template

<feature> is a kebab-case id (e.g. user-invite-flow). Fill the brief, then ask your agent
to "draft the spec" — sdd-spec turns it into sdd/specs/<feature>/spec.md.
EOF
                    ;;
                *) err "unknown sdd spec subcommand: '$_spec_cmd' (use new)"; exit 1 ;;
            esac ;;
        waves)
            _feat="${1:-}"; _dir="${2:-$PWD}"
            [ -n "$_feat" ] || { err "sdd waves: missing <feature> name"; exit 1; }
            _p="$_dir/sdd/specs/$_feat"
            [ -d "$_p" ] || { err "sdd waves: no spec at '$_p' — run 'sprout sdd spec new $_feat' first"; exit 1; }
            sdd_waves "$_p" ;;
        handoff)
            _feat="${1:-}"; _phase="${2:-}"; _dir="${3:-$PWD}"
            [ -n "$_feat" ]  || { err "sdd handoff: missing <feature> name"; exit 1; }
            [ -n "$_phase" ] || { err "sdd handoff: missing <phase> number"; exit 1; }
            _p="$_dir/sdd/specs/$_feat"
            [ -d "$_p" ] || { err "sdd handoff: no spec at '$_p' — run 'sprout sdd spec new $_feat' first"; exit 1; }
            sdd_handoff "$_p" "$_phase" "$_dir" ;;
        ""|-h|--help)
            cat <<EOF
sprout sdd — spec-driven development plane (works on a new or existing project)

Usage:
  sprout sdd init [dir]                      install the SDD kit + flow skills (def: .)
  sprout sdd spec new <feature> [dir]        scaffold a per-feature brief (sdd/specs/<feature>/brief.md)
  sprout sdd waves <feature> [dir]           show the execution waves (what runs parallel vs waits)
  sprout sdd handoff <feature> <phase> [dir] write a self-contained brief for one phase

Flow: edit sdd/config.yaml → 'sprout sdd spec new <feature>' → fill brief.md → "draft the
spec" → "plan it" → "build phase 1" → "verify". Multi-agent (opt-in): assign phases to agents
in plan.md, then 'sdd waves' to see the order and 'sdd handoff' to brief each agent.
EOF
            ;;
        *) err "unknown sdd subcommand: '$_sub' (use init|spec|waves|handoff)"; exit 1 ;;
    esac
}

# ── recipe runner ────────────────────────────────────────────────────────────

run_recipe() {
    TYPE="$1"; shift
    PROJECT_NAME=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --stack)       STACK="$2"; shift 2 ;;
            --db)          DB="$2"; shift 2 ;;
            --pm)          PM="$2"; shift 2 ;;
            --base)        BASE="$2"; shift 2 ;;
            --css)         CSS="$2"; shift 2 ;;
            --lang)        LANG="$2"; shift 2 ;;
            --linter)      LINTER="$2"; shift 2 ;;
            --test)        TESTING="$(echo "$2" | tr ',' ' ')"; shift 2 ;;
            --git)         GIT_INIT=1; shift ;;
            --no-git)      GIT_INIT=0; shift ;;
            --sdd)         SDD_INIT=1; shift ;;
            --no-sdd)      SDD_INIT=0; shift ;;
            --skills)      SKILLS_SEL="$(echo "$2" | tr ',' ' ')"; shift 2 ;;
            --agent)       AGENTS_SEL="$2"; shift 2 ;;
            --clis)        CLIS_INSTALL="$(echo "$2" | tr ',' ' ')"; shift 2 ;;
            --install-clis) INSTALL_CLIS=1; shift ;;
            --dry-run)     DRY_RUN=1; shift ;;
            -*)            err "unknown option: $1"; exit 1 ;;
            *)             [ -z "$PROJECT_NAME" ] && PROJECT_NAME="$1"; shift ;;
        esac
    done
    [ -n "$PROJECT_NAME" ] || { err "missing project name: sprout $TYPE <name>"; exit 1; }
    [ -f "$SPROUT_DIR/recipes/$TYPE.sh" ] || { err "type '$TYPE' has no recipe yet (Phase 2)"; exit 1; }

    [ -n "$SKILLS_SEL" ] || SKILLS_SEL="$(skills_for_type "$TYPE")"
    [ -n "$PM" ] || PM="$(default_pm_js)"
    PROJECT_DIR="$PWD/$PROJECT_NAME"
    export PROJECT_NAME PROJECT_DIR TYPE STACK PM AGENTS_SEL SKILLS_SEL DRY_RUN INSTALL_CLIS CLIS_INSTALL
    export BASE CSS LANG LINTER TESTING GIT_INIT DB SDD_INIT

    head "sprout — $TYPE: $PROJECT_NAME"
    . "$SPROUT_DIR/recipes/$TYPE.sh"
    recipe_run
}

# _type_uses_js_pm <type> <stack> — true when the chosen config scaffolds with a
# JS package manager, so the wizard should ask which one (pnpm by default).
#   web              — always (Astro/Vite)
#   desktop/tauri    — web frontend (create-tauri-app honours --manager)
#   mobile/react-native — Expo
#   ext/wxt          — wxt framework
# desktop/wails keeps its own npm default; fullstack has no JS stack yet.
_type_uses_js_pm() {
    case "$1" in
        web) return 0 ;;
        desktop) [ "$2" = tauri ] ;;
        mobile)  case "$2" in react-native|rn|expo) return 0 ;; *) return 1 ;; esac ;;
        ext)     [ "$2" = wxt ] ;;
        *) return 1 ;;
    esac
}

# ── wizard ───────────────────────────────────────────────────────────────────

wizard() {
    head "sprout — new project"

    # 1 · type
    # Only types with a recipe are buildable; the rest show "(soon)" and re-prompt.
    while :; do
        TYPE="$(pick_one 'What do you want to build?' web "$(printf '%s\n' \
            'web|web        Astro or Vanilla  →  CSS  →  JS/TS' \
            'fullstack|fullstack  Laravel · Django · FastAPI' \
            'desktop|desktop    Tauri · Wails · Fyne · egui' \
            'mobile|mobile     React Native · Flutter · Kotlin · Swift' \
            'ext|ext        Chromium extension (MV3)' \
            'cli|cli        CLI tool · posix sh · Rust · Go')")"
        [ -f "$SPROUT_DIR/recipes/$TYPE.sh" ] && break
        warn "'$TYPE' isn't ready yet — it lands in Phase 2. Pick 'web' for now."
    done

    PROJECT_NAME="$(ask_value '     project name' "my-$TYPE")"

    # recipe-specific stack questions (web: base/css/lang/linter/test/git).
    # Sourcing the recipe defines recipe_run (+ optional recipe_configure).
    if [ -f "$SPROUT_DIR/recipes/$TYPE.sh" ]; then
        . "$SPROUT_DIR/recipes/$TYPE.sh"
        command -v recipe_configure >/dev/null 2>&1 && recipe_configure
    fi

    # JS package manager — only asked for configs that scaffold with one
    # (web, desktop/tauri, mobile/react-native, ext/wxt). Offer all four, tagged.
    if _type_uses_js_pm "$TYPE" "$STACK"; then
        _pm_items="$(for _p in pnpm npm yarn bun; do
            if have "$_p"; then printf '%s|%s  (installed)\n' "$_p" "$_p"
            else               printf '%s|%s  (missing)\n'   "$_p" "$_p"; fi
        done)"
        _pm_default="$(for _p in pnpm npm yarn bun; do have "$_p" && { echo "$_p"; break; }; done)"
        [ -n "$_pm_default" ] || _pm_default="npm"
        PM="$(pick_one 'Package manager' "$_pm_default" "$_pm_items")"
        if ! have "$PM"; then
            if ask_yn "     $PM isn't installed — install it now?" y; then ensure_pm "$PM"
            else warn "$PM not installed — scaffolding will fall back to an empty dir"; fi
        fi
    fi

    # skills — checkbox list (all candidates preselected), each with what it's for
    _skill_items="$(skill_items_for_type "$TYPE")"
    _skill_pre="$(skills_for_type "$TYPE")"
    SKILLS_SEL="$(pick_many 'Skills to vendor  (each line says what it is for)' "$_skill_pre" "$_skill_items")"

    # agent context — checkbox list (claude preselected)
    _agent_items="$(printf '%s\n' claude gemini codex copilot opencode)"
    AGENTS_SEL="$(pick_many 'Agent context to wire' 'claude' "$_agent_items")"
    [ -n "$AGENTS_SEL" ] || AGENTS_SEL="claude"

    # CLIs — checkbox list; missing ones preselected to install
    _cli_items="$(clis_for_type "$TYPE")"
    _cli_pre="$(clis_missing "$TYPE")"
    CLIS_INSTALL="$(pick_many 'Global CLIs to install (already-present ones are skipped)' "$_cli_pre" "$_cli_items")"

    # SDD plane — opt-in spec-driven flow (kit + sdd-* skills). Off by default;
    # you can also add it later with `sprout sdd init`.
    _sdd_flag=--no-sdd
    if ask_yn 'Install the SDD plane? (spec → plan → build → verify flow)' n; then _sdd_flag=--sdd; fi

    run_recipe "$TYPE" "$PROJECT_NAME" \
        --pm "$PM" \
        --skills "$(echo "$SKILLS_SEL" | tr ' ' ',')" \
        --agent "$AGENTS_SEL" \
        --clis "$(echo "$CLIS_INSTALL" | tr ' ' ',')" \
        "$_sdd_flag"
}

# ── dispatch ─────────────────────────────────────────────────────────────────

# allow a leading --dry-run before the subcommand (e.g. `sprout --dry-run web x`)
case "${1:-}" in --dry-run) DRY_RUN=1; shift ;; esac

cmd="${1:-}"
case "$cmd" in
    ""|wizard)                         wizard ;;
    web|fullstack|desktop|mobile|ext|cli)  run_recipe "$@" ;;
    list)                              cmd_list ;;
    doctor)                            cmd_doctor ;;
    skills)                            shift; cmd_skills "$@" ;;
    sdd)                               shift; cmd_sdd "$@" ;;
    -h|--help)                         usage ;;
    --version)                         echo "sprout $VERSION" ;;
    *)                                 err "unknown command: $cmd"; usage; exit 1 ;;
esac
